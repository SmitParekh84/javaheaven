# Copy this to .env.local and fill in your values

# Your Express backend URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# MongoDB connection string (for tenant config only — menus/orders stay in Express backend)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/javaheaven

# Super admin dashboard password
SUPER_ADMIN_PASSWORD=change-this-to-something-secure
